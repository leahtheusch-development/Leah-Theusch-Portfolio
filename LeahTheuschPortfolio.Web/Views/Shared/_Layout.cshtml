<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LeahTheuschPortfolio.Web</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Grandstander:wght@600;700;800&family=Yellowtail&family=Karla:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/dist/main.css" asp-append-version="true" />
</head>
<body>
    <header>
        <partial name="Components/_Nav" />
    </header>
    
    <div class="container">
        <main class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* Will be placed in reusable partial in later pr  *@
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - LeahTheuschPortfolio.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="~/dist/main.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
